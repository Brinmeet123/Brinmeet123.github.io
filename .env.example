# Copy to .env.local and fill in values.
# SQLite path is relative to the prisma/ folder (where schema.prisma lives).

DATABASE_URL="file:./dev.db"

# Required in production. In local dev, a built-in fallback is used if unset.
AUTH_SECRET="use-a-long-random-string-at-least-32-chars"
AUTH_URL="http://localhost:3001"

RESEND_API_KEY=""
RESEND_FROM="VDS <onboarding@resend.dev>"
