# Copy to .env.local for local development.

# PostgreSQL (required for Vercel and production — SQLite cannot run on serverless).
# Free options: Neon (https://neon.tech), Supabase, Vercel Postgres.
# Example Neon:
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth.js — use a long random string in production (e.g. openssl rand -base64 32)
AUTH_SECRET="use-a-long-random-string-at-least-32-chars"
AUTH_URL="http://localhost:3001"

# Resend (welcome email on signup): https://resend.com/api-keys
# 1) Add RESEND_API_KEY to Vercel (Production) and redeploy.
# 2) Add + verify your domain at https://resend.com/domains (DNS records).
# 3) Set RESEND_FROM to an address on that domain, e.g. "VDS <noreply@yourdomain.com>".
#    Default onboarding@resend.dev is for testing only and often will not reach real inboxes.
RESEND_API_KEY=""
RESEND_FROM="VDS <noreply@yourdomain.com>"
